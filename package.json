{
  "name": "eiscord",
  "version": "0.1.0",
  "private": true,
  "description": "Discord-like realtime community collaboration system.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "deps:build":    "bash scripts/deps/build.sh",
    "db:generate":   "prisma generate --schema=prisma/schema.prisma",
    "db:migrate":    "prisma migrate dev --schema=prisma/schema.prisma",
    "db:seed":       "tsx prisma/seed.ts",
    "infra:up":      "docker compose up -d postgres redis minio minio-init",
    "infra:down":    "docker compose down",
    "e2e:audio":     "node scripts/generate-test-audio.mjs",
    "dev":           "bash scripts/dev/full.sh",
    "dev:api":       "bash scripts/dev/api.sh",
    "dev:web":       "bash scripts/dev/web.sh",
    "db:reset":      "bash scripts/db/reset.sh",
    "db:test:reset": "bash scripts/db/test-reset.sh",
    "e2e:api":       "bash scripts/e2e/api.sh",
    "e2e:web":       "bash scripts/e2e/web.sh",
    "e2e:voice":     "bash scripts/e2e/voice.sh",
    "e2e":           "bash scripts/e2e/all.sh",
    "check":         "bash scripts/check/all.sh",
    "setup":         "bash scripts/setup.sh",
    "build":         "pnpm -r --if-present build",
    "typecheck":     "bash scripts/deps/build.sh && pnpm -r --if-present typecheck",
    "test":          "pnpm -r --if-present test",
    "lint":          "pnpm -r --if-present lint",
    "format":        "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,md,css,yml,yaml}\"",
    "perf:k6":       "k6 run scripts/k6/m6-realtime-load.js"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0"
  },
  "devDependencies": {
    "@eiscord/config": "workspace:*",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.43.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^15.0.0",
    "prettier": "^3.2.5",
    "prisma": "^5.13.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
