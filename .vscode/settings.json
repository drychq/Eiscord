{
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.build.enableMagicComments": false,
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.auxDir": "%WORKSPACE_FOLDER%/build",
  "latex-workshop.latex.outDir": "%WORKSPACE_FOLDER%/output",
  "latex-workshop.latex.tools": [
    {
      "name": "workspace-latexmk-direct",
      "command": "latexmk",
      "args": [
        "-xelatex",
        "-cd",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-outdir=%WORKSPACE_FOLDER%/output",
        "-auxdir=%WORKSPACE_FOLDER%/build",
        "%DOCFILE%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "workspace-latexmk-output",
      "tools": [
        "workspace-latexmk-direct"
      ]
    }
  ],
  "latex-workshop.latex.recipe.default": "workspace-latexmk-output",
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux",
    "*.bbl",
    "*.bcf",
    "*.blg",
    "*.fdb_latexmk",
    "*.fls",
    "*.log",
    "*.out",
    "*.run.xml",
    "*.synctex.gz",
    "*.toc"
  ]
}
