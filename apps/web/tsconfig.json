{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": ["vite/client"]
  },
  "references": [
    {
      "path": "../../packages/shared"
    }
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"],
  "exclude": ["dist", "node_modules"]
}
