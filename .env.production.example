# Copy to .env.production on the server and replace every placeholder value.
# Use: docker compose --env-file .env.production -f deploy/docker-compose.prod.yml ...

COMPOSE_PROJECT_NAME=eiscord

# Public DNS. All records should point to the VPS public IPv4.
PUBLIC_WEB_DOMAIN=eiscord.example.com
S3_PUBLIC_DOMAIN=s3.eiscord.example.com
ACME_EMAIL=admin@example.com
MEDIASOUP_ANNOUNCED_IP=203.0.113.10

# Public browser-facing URLs. Vite bakes PUBLIC_* into the web image at build time.
PUBLIC_WEB_ORIGIN=https://eiscord.example.com
PUBLIC_API_BASE_URL=https://eiscord.example.com/api/v1
PUBLIC_REALTIME_URL=https://eiscord.example.com/realtime

# PostgreSQL runs inside Compose and is not published to the internet.
POSTGRES_USER=eiscord
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_DB=eiscord

# JWT/session secrets. Generate independent high-entropy values.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-token-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-token-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# S3-compatible object storage. For self-hosted MinIO, S3_ENDPOINT must be public HTTPS.
S3_ENDPOINT=https://s3.eiscord.example.com
S3_BUCKET=eiscord-production
S3_ACCESS_KEY=replace-with-a-long-random-minio-access-key
S3_SECRET_KEY=replace-with-a-long-random-minio-secret-key
UPLOAD_MAX_BYTES=10485760

# Realtime and presence.
SERVER_MEMBER_LIMIT=5000
LOG_LEVEL=info
PRESENCE_SWEEP_INTERVAL_MS=5000
PRESENCE_OFFLINE_GRACE_MS=45000

# Voice media. Keep these aligned with deploy/docker-compose.prod.yml port publishing.
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100
MEDIASOUP_NUM_WORKERS=2
MEDIA_HEALTH_PORT=3001
TURN_REALM=eiscord.example.com
TURN_URL=turn:turn.eiscord.example.com:3478?transport=udp
TURN_SHARED_SECRET=replace-with-a-long-random-turn-shared-secret
TURN_CREDENTIAL_TTL_SECONDS=300
TURN_RELAY_MIN_PORT=49160
TURN_RELAY_MAX_PORT=49200
VOICE_MAX_PARTICIPANTS_PER_ROOM=20
VOICE_NEGOTIATION_TIMEOUT_MS=30000
VOICE_NEGOTIATION_SWEEP_INTERVAL_MS=5000

# Email via Resend (https://resend.com). Create an API key and verify your sending domain.
RESEND_API_KEY=replace-with-resend-api-key
MAIL_FROM_EMAIL=noreply@eiscord.example.com
MAIL_FROM_NAME=Eiscord
PASSWORD_RESET_TTL_MINUTES=15
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_MAX_ATTEMPTS=5
