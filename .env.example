NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://eiscord:eiscord@localhost:5432/eiscord
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=eiscord-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
PUBLIC_REALTIME_URL=http://localhost:3000/realtime
PUBLIC_WEB_ORIGIN=http://localhost:5173
UPLOAD_MAX_BYTES=10485760
SERVER_MEMBER_LIMIT=5000
LOG_LEVEL=debug
REDIS_CONNECT_IN_TEST=false
REALTIME_SWEEP_IN_TEST=false
PRESENCE_SWEEP_INTERVAL_MS=5000
PRESENCE_OFFLINE_GRACE_MS=45000
